ANTHROPIC_API_KEY=your-key-here

# Optional: set to "true" to skip Claude/API calls entirely and stream back canned mock data
# instead, for testing the UI without spending API credits.
MOCK_MODE=

# Optional locally, but required for any public deployment: if set, the backend requires this
# password on every request (sent as the X-App-Password header). Leave unset only for local dev —
# unset in production means anyone who finds the URL can run searches on your API credits.
APP_PASSWORD=

# Required only in production: the deployed frontend's origin, for CORS (e.g. a Vercel URL).
# localhost is always allowed for local dev regardless of this setting.
FRONTEND_URL=

# Optional: raises Semantic Scholar rate limits (unauthenticated requests are heavily throttled)
SEMANTIC_SCHOLAR_API_KEY=

# Optional but recommended: anonymous OpenAlex search is heavily rate-limited (free key at openalex.org)
OPENALEX_API_KEY=

# Optional: your email, joins OpenAlex's "polite pool" for higher rate limits
OPENALEX_MAILTO=
