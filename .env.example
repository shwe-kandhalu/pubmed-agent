ANTHROPIC_API_KEY=your-key-here

# Optional: if set, the backend requires this password on every request
# (sent as the X-App-Password header). Leave unset to disable auth (local dev default).
APP_PASSWORD=

# Optional: raises Semantic Scholar rate limits (unauthenticated requests are heavily throttled)
SEMANTIC_SCHOLAR_API_KEY=

# Optional but recommended: anonymous OpenAlex search is heavily rate-limited (free key at openalex.org)
OPENALEX_API_KEY=

# Optional: your email, joins OpenAlex's "polite pool" for higher rate limits
OPENALEX_MAILTO=
